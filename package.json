{
  "name": "create-portofor",
  "version": "0.1.0",
  "description": "Scaffold a Portofor project",
  "type": "module",
  "bin": {
    "create-portofor": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "templates/default/",
    "!templates/default/node_modules",
    "!templates/default/dist",
    "!templates/default/.astro",
    "!templates/default/*.lock",
    "!templates/default/package-lock.json",
    "!templates/default/pnpm-lock.yaml"
  ],
  "keywords": [
    "npm-init",
    "scaffold",
    "blog",
    "generator"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
