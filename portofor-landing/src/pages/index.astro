---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HowItWork from '../components/sections/HowItWork.astro';

const siteTitle = "Portofor";
const description = "A dark-minimalist identity of yours, cooked with Astro";
---

<Layout title={siteTitle} description={description} backToLink={false}>
	<Header /> 
	<Hero />
	<HowItWork />
	<Footer />
</Layout>
