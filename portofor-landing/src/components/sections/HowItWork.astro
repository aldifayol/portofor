---
import { Card, CardContent } from "@/components/ui/card";
import { Code, ChevronRight, Cog, FileText } from "@lucide/astro";

const iconMap = {
  Code,
  Cog,
  FileText,
};

const textColorMap: Record<string, string> = {
  blue: "text-blue-400",
  purple: "text-purple-400",
  green: "text-green-400",
};

const bgColorMap: Record<string, string> = {
  blue: "bg-blue-500/20",
  purple: "bg-purple-500/20",
  green: "bg-green-500/20",
};

type IconName = keyof typeof iconMap;

const workflowData = [
  {
    title: "1. Create Portfolio",
    icon: "Code",
    theme: "blue",
    desc: ["Run npx create-neo-portfolio", "Interactive mode or provide project name", "Scaffolds portfolio automatically", "Installs dependencies and starts dev server"]
  },
  {
    title: "2. Edit Content",
    icon: "Cog",
    theme: "green",
    desc: ["Open src/components/constants/data.ts", "Fill in your details (name, links, projects)", "Update contact form endpoint", "Customize sections as needed"]
  },
  {
    title: "3. Deploy",
    icon: "FileText",
    theme: "purple",
    desc: ["Deploy to your favorite PaaS", "Portfolio ready in minutes", "Clean up unused sections"]
  }
]

---

<section
  id="how-it-works"
  class="pt-32 pb-8 px-4 border-t backdrop-blur-md border-white/5 snap-section"
>
  <div class="container mx-auto">
    <div class="text-center mb-12 sm:mb-16 lg:mb-20">
      <h2 class="text-3xl sm:text-2xl md:text-3xl lg:text-4xl font-bold mb-4 sm:mb-6 lg:mb-8 text-white">
        How it works
      </h2>
      <p class="text-md sm:text-xl lg:text-xl text-gray-300 max-w-4xl mx-auto leading-relaxed px-2">
        Understanding the magic behind the one-command portfolio setup
      </p>
    </div>

    <div class="max-w-5xl mx-auto">
      {/* How it Works Process */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-3 mb-12 lg:mb-2">
        <!-- { mapping data} -->
        {workflowData.map(({title, icon, theme, desc}) => {
          const Icon = iconMap[icon as IconName];

          return (
            <Card className="bg-white/5 backdrop-blur-xl border border-white/5 shadow-xl">
              <CardContent className="p-6 lg:p-6">
                <div class="flex items-center mb-4 lg:mb-6">
                  <div class={`w-8 h-8 sm:w-9 sm:h-9 ${bgColorMap[theme]} rounded-full flex items-center justify-center mr-3 lg:mr-4`}>
                  <Icon class={`w-3 h-3 sm:w-3 sm:h-3 ${textColorMap[theme]}`} />
                  </div>
                  <h3 class="text-xl sm:text-lg font-bold text-white">
                    {title}
                  </h3>
                </div>
                  <ul class="space-y-2 lg:space-y-3 text-gray-300 text-sm sm:text-sm">
                    {desc.map((text) => (
                      <li class="flex items-start">
                        <ChevronRight class={`w-4 h-4 mr-2 mt-0.5 sm:mt-1 ${textColorMap[theme]} shrink-0`}/>
                        <span>{text}</span>
                      </li>
                    ))}
                  </ul>
              </CardContent>
            </Card>
          );
        })}

      </div>
      {/* Flow Diagram */}
      <div class="mt-12 lg:mt-16">
        <Card className="bg-white/5 backdrop-blur-xl border-white/5 shadow-xl">
          <CardContent className="p-6 lg:p-8">
            <h3 class="text-xl sm:text-2xl font-bold mb-6 lg:mb-8 text-center text-white">
              Installation Flow
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-4">
              <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 bg-blue-500/20 rounded-full flex items-center justify-center mb-3">
                  <span class="text-blue-400 font-bold text-lg sm:text-xl">
                    1
                  </span>
                </div>
                <h4 class="font-semibold text-white mb-2 text-sm sm:text-base">
                  Create
                </h4>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Run CLI command
                </p>
              </div>

              <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 bg-green-500/20 rounded-full flex items-center justify-center mb-3">
                  <span class="text-green-400 font-bold text-lg sm:text-xl">
                    2
                  </span>
                </div>
                <h4 class="font-semibold text-white mb-2 text-sm sm:text-base">
                  Edit
                </h4>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Customize your data
                </p>
              </div>

              <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 bg-purple-500/20 rounded-full flex items-center justify-center mb-3">
                  <span class="text-purple-400 font-bold text-lg sm:text-xl">
                    3
                  </span>
                </div>
                <h4 class="font-semibold text-white mb-2 text-sm sm:text-base">
                  Deploy
                </h4>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Launch your portfolio
                </p>
              </div>

              <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 bg-yellow-400/20 rounded-full flex items-center justify-center mb-3">
                  <span class="text-yellow-400 font-bold text-lg sm:text-xl">
                    ✓
                  </span>
                </div>
                <h4 class="font-semibold text-white mb-2 text-sm sm:text-base">
                  Ready!
                </h4>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Portfolio is live
                </p>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</section>