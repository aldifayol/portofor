---
import { Github, Package} from '@lucide/astro'
import { Button } from "@/components/ui/button"

const navItems = [
    { id: 'features', label: 'Features', href: '/#hero-section' },
    { id: 'how-it-works', label: 'How it Works', href: '/#how-it-works' },
    { id: 'docs', label: 'Docs', href: '/docs' },
  ];

---
<header class="sticky z-50 top-0 px-4 pt-5">
  <div class="z-50 w-full max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between backdrop-blur-xs bg-white/1 border border-white/10 shadow-xl">
    {/* Left */}
    <a
      href="/"
      class="flex items-center space-x-1 z-10 cursor-pointer transition-all duration-200 hover:opacity-90"
      >
      <img src="/favicon.png" class="h-8 w-8 text-white" alt="Portofor Icon">
      <span class="text-lg sm:text-xl ml-1 font-semibold text-white">Portofor</span>
    </a>

    {/* Center */}
    <nav class="hidden lg:flex items-center space-x-8 absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-gray-300 hover:text-white transition-all duration-300 ease-out text-sm font-medium bg-transparent border-none cursor-pointer relative group">
          {item.label}
          <span class="absolute inset-x-0 -bottom-1 h-px bg-white transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out"></span>
        </a>
      ))}
    </nav>

    {/* Right */}
    <div class="flex items-center space-x-2 sm:space-x-4 z-10">
      <Button
        variant="ghost"
        className=" bg-white/1 backdrop-blur-md border border-white/20 text-white hover:text-white hover:bg-white/10 transition-all duration-200"
        >
        <a
          href="https://github.com/aldifayol/portofor.my.id"
          target="_blank"
          rel="noopener noreferrer">
          <Github class="h-4 w-4" />
        </a>
      </Button>

      <Button
        className=" bg-white/1 backdrop-blur-md border border-white/20 text-white hover:text-white hover:bg-white/10 transition-all duration-200"
        >
        <a
          class="flex gap-2"
          href="https://www.npmjs.com/package/create-portofor"
          target="_blank"
          rel="noopener noreferrer">
          <Package class="h-4 w-4" />
          <span class="sm:inline">NPM</span>
        </a>
      </Button>
    </div>
  </div>
</header>